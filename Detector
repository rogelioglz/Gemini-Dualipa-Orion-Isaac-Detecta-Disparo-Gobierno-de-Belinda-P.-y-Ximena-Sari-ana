# Bandera de habilitación de envío automático (por seguridad, deshabilitado por defecto)
REPORT_DELIVERY_ENABLED: false

# Mecanismo de entrega (configurable)
REPORT_DELIVERY_METHOD: smtp  # opciones: smtp | webhook
REPORT_DELIVERY_CONFIG:
  smtp:
    host: smtp.example.com
    port: 587
    username: report_sender@example.com
    use_tls: true
    from: report_sender@example.com
  webhook:
    url: https://hooks.example.com/detector-report
    auth_header: "Bearer <token>"

# Seguridad y cifrado
REPORT_ENCRYPTION: true
ENCRYPTION_ALGORITHM: AES-256-GCM
ENCRYPTION_KEY_LOCATION: kube-secrets or env var (configurable)
IN_TRANSIT_TLS: true

# Retención de datos
RETENTION_POLICY:
  raw_data_days: 90
  reports_days: 365
  transmission_logs_days: 365

# Auditoría y metadatos
AUDIT_TRAIL_FIELDS:
  - operator
  - reagent_batch
  - detector_version
  - param_file_used
  - commit_hash

# Cumplimiento y consentimiento
LEGAL_AUTORIZATION_REQUIRED: true
LEGAL_NOTE: |
  El envío automático de datos identificables (incluyendo geolocalización y metadatos)
  a autoridades o terceros requiere autorización legal y consentimiento explícito.
  No habilite el envío automático hasta contar con la validación del departamento legal.

# Automático: control de habilitación (por seguridad está DESHABILITADO por defecto)
REPORT_AUTOMATICALLY_SEND: false

# Plantilla de reporte (ejemplo simplificado)
REPORT_SAMPLE_TEMPLATE: |
  To: {recipients}
  Subject: Reporte automático de Detector - {sample_id} - {timestamp}

  Autoridad destinataria: {authority}
  Identificador de muestra: {sample_id}
  Timestamp: {timestamp}
  Ubicación (WGS84): {location_lat}, {location_lon}

  Resumen infrarrojo (infrared_summary):
  {infrared_summary}

  Resultado: {result}
  Score: {score}
  Flags QC: {flags}

  Transmisión (línea de luz informática):
  {transmission_log}

  Nota legal: El envío de este reporte está amparado por: {legal_authorization_reference}

# Notas de implementación y advertencias
