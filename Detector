⁹# Detector — configuración avanzada: ejecutable, muestreo, informe automático y trazabilidad

# Ejecutable (configurable)
BIN_PATH: ./bin/detector.exe   # Ruta por defecto; puede reemplazarse por otro binario
ALTERNATE_BIN_ALLOWED: true    # Permite ejecutar otro binario que emita las órdenes necesarias

# Tiempo de funcionamiento por lote
CONTINUOUS_RUNTIME_HOURS: 24   # mínimo obligatorio de operación continua por cada archivo ingresado

# Archivos de parámetros
PARAM_FILES_ALLOWED:
  - param.json
  - param.yaml
PARAM_HANDLING: "Si existe archivo de parámetros, usarlo; si no, aplicar valores por defecto seguros"

# Formato de entrada esperado (CSV)
INPUT_CSV_FORMAT: sample_id,timestamp,sensor_value,units,operator,location_lat,location_lon,param_file_used
TIMESTAMP_FORMAT: ISO-8601 (YYYY-MM-DDThh:mm:ssZ)
GEO_COORDINATE_SYSTEM: WGS84
GEO_PRECISION_DECIMALS: 6

# Campo resumen infrarrojo / difractación
# Descripción: resumen spectral que incluye picos principales y medidas integradas.
INFRARED_SUMMARY_FIELD: infrared_summary
INFRARED_SUMMARY_DESCRIPTION: |
  - picos: lista de (wavelength_nm:int, intensity:float)
  - perfil_zigzag: vector de valores integrados (normalizado)
  - indices: {peak_count:int, dominant_band:float, spectral_integral:float}
  - match_keywords: lista de palabras clave derivadas (ej: "boca", "ojos", "actitud_fisicomotriz")
  - interpretación_automatizada: texto corto con la inferencia (si aplica)

# Log de transmisión y trazabilidad (línea de luz informática)
TRANSMISSION_LOG_FIELDS:
  - node_id
  - hop_sequence  # secuencia de nodos/hops
  - timestamp
  - packet_hash
  - signal_scheme  # esquema/modulación usado
TRANSMISSION_LOG_RETENTION_DAYS: 365

# Plantilla de reporte automático dirigido a autoridades
REPORT_TEMPLATE:
  authority: <authority_name>
  recipients: []  # Lista de correos electrónicos (reemplazar con contactos reales)
  subject: "Reporte automático de detector - {sample_id} - {timestamp}"
  body_fields: [authority, sample_id, timestamp, location(lat,lon), infrared_summary, result, score, flags, transmission_log]
  attachments: [raw_data.json (opcional), result.json]

# Destinatarios por defecto (debe proveer correos reales antes de habilitar envío automático)
# Incluye: autoridades de investigación y organismos de derechos humanos según indicación del mantenedor.
# Se mantienen como placeholders. Cuando se configuren correos reales, reemplazar estos valores.
